# Plantilla — copiá a la raíz del repo:
#   cp notebooks/.env.pint.example .env
# Completá solo NVIDIA_JUDGE_API_KEY y NVIDIA_COLLECTOR_API_KEY.

# ══ SECRETS ════════════════════════════════════════════════════════════════════
NVIDIA_JUDGE_API_KEY=
NVIDIA_COLLECTOR_API_KEY=
# API key Sentinel v2 / HF Inference (Read) — https://huggingface.co/settings/tokens
# Aceptar licencia: https://huggingface.co/rogue-security/prompt-injection-jailbreak-sentinel-v2
SENTINEL_API_KEY=
# Alias opcionales (SENTINEL_API_KEY tiene prioridad):
# INJECTION_CLASSIFIER_API_KEY=
# HF_TOKEN=

# ══ Clasificador — Sentinel v2 vía HF Inference Endpoint (scale-to-zero) ═════
# IMPORTANTE: backend=hf requiere HF_INFERENCE_ENDPOINT dedicado (no serverless)
# Crear endpoint: https://ui.endpoints.huggingface.co/new
#   - Modelo: rogue-security/prompt-injection-jailbreak-sentinel-v2
#   - Tarea: Text Classification
#   - Instancia: CPU (más barata)
#   - Scale-to-zero: ON
#
# Aceptar licencia antes: https://huggingface.co/rogue-security/prompt-injection-jailbreak-sentinel-v2
INJECTION_CLASSIFIER_ENABLED=true
INJECTION_CLASSIFIER_BACKEND=hf
INJECTION_MODEL=rogue-security/prompt-injection-jailbreak-sentinel-v2
INJECTION_THRESHOLD=0.5
INJECTION_THRESHOLD_STRICT=0.15
INJECTION_HIGH_CONFIDENCE=0.995
INJECTION_BATCH_SIZE=16

# ══ HF Inference Endpoint (REQUERIDO para backend=hf) ═════════════════════════
# URL del endpoint dedicado (copiar de HF UI después de crear)
HF_INFERENCE_ENDPOINT=https://xxxxxxxx.us-east-1.aws.endpoints.huggingface.cloud

# Resiliencia para scale-to-zero
HF_INFERENCE_TIMEOUT=180
HF_INFERENCE_RETRIES=5
HF_INFERENCE_RETRY_DELAY=5.0
HF_INFERENCE_PROVIDER=auto
# Hilos paralelos para scoring HTTP (benchmark). Subir si el endpoint aguanta;
# bajar a 1 si hay rate limit. Con Space CPU free, 4–8 suele ir bien.
HF_INFERENCE_WORKERS=8
HF_HOME=notebooks/data/hf-cache

# Política ante fallo de inferencia (tras agotar reintentos):
#   true  = fail-open → score 0.0 (benigno). Evita tormenta de alertas con endpoint flaky.
#   false = fail-closed → score 1.0 (malicioso). Postura segura para SIEM en prod.
INJECTION_FAIL_OPEN=true

# ══ Detection modes — control de comportamiento adaptativo ════════════════════
# production: umbral 0.5, benign_guard habilitado
# strict/benchmark: umbral 0.15, multi-variant scoring
DETECTION_MODE=production
BENIGN_GUARD_ENABLED=true
GRAY_ZONE_LOW=0.15
GRAY_ZONE_HIGH=0.85
DETECTION_JUDGE_GRAY_ZONE_ONLY=0

# ══ PINT benchmark ═══════════════════════════════════════════════════════════
PINT_SKIP_OLLAMA=1
PINT_DATASET_PATH=notebooks/data/pint-public-full.yaml
PINT_MAX_SAMPLES=0

# ══ NVIDIA NIM — judge L3 ════════════════════════════════════════════════════
NVIDIA_JUDGE_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
JUDGE_THRESHOLD=0.65
DETECTION_JUDGE_ENABLED=auto

# ══ NVIDIA NIM — collector / victim LLM ══════════════════════════════════════
NVIDIA_COLLECTOR_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_COLLECTOR_BASE_URL=https://integrate.api.nvidia.com/v1

# ══ Ensemble (deshabilitado por defecto) ══════════════════════════════════════
# Combina Sentinel v2 + Llama Prompt Guard 2 para mayor cobertura.
# Regla: ataque si Sentinel >= 0.5 O Llama >= 0.5
ENSEMBLE_ENABLED=false
ENSEMBLE_BACKEND=local
ENSEMBLE_SECONDARY_MODEL=meta-llama/Llama-Prompt-Guard-2-86M
ENSEMBLE_SECONDARY_THRESHOLD=0.5
